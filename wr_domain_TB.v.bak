`timescale 1ns / 1ps

module wr_domain_TB;

    // Parameters matching the UUT (Depth of 16)
    localparam ADDR_WIDTH_TB = 4;

    // Signal Declarations
    reg  wclk_TB;
    reg  wrst_n_TB;
    reg  wr_en_TB;
    reg  [ADDR_WIDTH_TB:0] rd_ptr_gray_sync_TB; // Read pointer arriving from the slow domain

    wire [ADDR_WIDTH_TB-1:0] wr_addr_TB;
    wire [ADDR_WIDTH_TB:0]   wr_ptr_gray_TB;
    wire wfull_TB;

    // Instantiate the Unit Under Test (UUT)
    wr_domain #(
        .ADDR_WIDTH(ADDR_WIDTH_TB)
    ) uut (
        .wclk(wclk_TB),
        .wrst_n(wrst_n_TB),
        .wr_en(wr_en_TB),
        .rd_ptr_gray_sync(rd_ptr_gray_sync_TB),
        .wr_addr(wr_addr_TB),
        .wr_ptr_gray(wr_ptr_gray_TB),
        .wfull(wfull_TB)
    );

    // Clock Generation (10ns period -> 100MHz)
    always #5 wclk_TB = ~wclk_TB;

    initial begin
        // --- Phase 1: System Initialization ---
        wclk_TB = 1'b0;
        wrst_n_TB = 1'b0; // Assert reset (active low)
        wr_en_TB = 1'b0;
        
        // Simulate a completely empty FIFO, so the read pointer is initially 0
        rd_ptr_gray_sync_TB = 5'b00000; 

        // De-assert reset after 2 clock cycles
        repeat(2) @(posedge wclk_TB);
        wrst_n_TB = 1'b1;
        @(posedge wclk_TB);

        // --- Phase 2: Fill the FIFO to Trigger 'wfull' ---
        // Keep write enable high for 18 clock cycles.
        // Since the FIFO depth is 16, we expect it to block after 16 writes.
        wr_en_TB = 1'b1;
        repeat(18) @(posedge wclk_TB);

        // Disable writing to observe the static state of the full flag
        wr_en_TB = 1'b0;
        repeat(3) @(posedge wclk_TB);

        // --- Phase 3: Read Simulation and FIFO Release ---
        // Simulate the slow read domain popping one data word.
        // It sends back an updated read pointer (Binary: 1 -> Gray code: 00001).
        rd_ptr_gray_sync_TB = 5'b00001; 
        
        // Wait and observe the 'wfull' flag dropping back to 0
        repeat(3) @(posedge wclk_TB);
        
        // Attempt to write again now that 1 slot has freed up
        wr_en_TB = 1'b1;
        repeat(2) @(posedge wclk_TB);

        // End Simulation
        $display("========================================");
        $display("          SIMULATION COMPLETE           ");
        $display("========================================");
        $stop;
    end

    // -------------------------------------------
    // Console Monitor
    // -------------------------------------------
    initial begin
        $display(" Time | wr_en | wr_addr | wr_ptr_gray | rd_ptr_gray_sync || wfull ");
        $display("------------------------------------------------------------------");
        $monitor("%5t |   %b   |   %2d    |    %b    |      %b      ||   %b   ", 
                 $time, wr_en_TB, wr_addr_TB, wr_ptr_gray_TB, rd_ptr_gray_sync_TB, wfull_TB);
    end

endmodule