`timescale 1ns / 1ps

module system_top #(
    parameter UART_CLK_FREQ = 10_000_000,
    parameter UART_BAUD_RATE = 9600,
    parameter FIFO_DEPTH = 32
)(
    // System Clocks and Reset
    input  wire       clk_fast,   // Fast clock for FIR & FIFO write domain
    input  wire       clk_slow,   // Slow clock for UART & FIFO read domain
    input  wire       rst_n,      // Global asynchronous reset (active low)
    
    // Data Input Interface (Fast Domain)
    input  wire [7:0] data_in,
    input  wire       valid_in,

    // UART Output Interface (Slow Domain)
    output wire       tx_serial,
    output wire       tx_busy,
    
    // System Status
    output wire       wfull       // Indicates if the internal FIFO is full
);

    // =================================================================
    // Internal Interconnect Wires
    // =================================================================
    wire        clk_en;
    wire        gated_clk_fast;
    
    wire [15:0] fir_data_out;
    wire        fir_valid_out;
    
    wire [15:0] fifo_rdata;
    wire        fifo_empty;
    wire        fifo_rinc;

    // =================================================================
    // 1. Power Manager (Generates Clock Enable)
    // =================================================================
    // Evaluates valid_in and controls the clock enable signal[cite: 77, 78].
    PowerManager pm_inst (
        .data_in  (data_in),
        .valid_in (valid_in),
        .clk      (clk_fast),
        .clk_en   (clk_en)
    );

    // =================================================================
    // 2. Clock Gater (Altera/Intel IP)
    // =================================================================
    // Gates the fast clock based on the enable signal from PowerManager[cite: 55].
    altclkctrl_0 clk_gater_inst (
        .inclk  (clk_fast),
        .ena    (clk_en),
        .outclk (gated_clk_fast)
    );

    // =================================================================
    // 3. FIR Filter (4-Tap)
    // =================================================================
    // Processes the incoming 8-bit data into 16-bit filtered data.
    FIR_4Tap fir_inst (
        .data_in        (data_in),
        .valid_in       (valid_in),
        .gated_clk_fast (gated_clk_fast),
        .rst_n          (rst_n),
        .data_out       (fir_data_out),
        .valid_out      (fir_valid_out)
    );

    // =================================================================
    // 4. Asynchronous FIFO (Crosses domains: Fast -> Slow)
    // =================================================================
    // Buffers the FIR output and safely crosses clock domains[cite: 38, 48, 50].
    async_fifo_top #(
        .DATA_WIDTH(16),
        .DEPTH(FIFO_DEPTH)
    ) async_fifo_inst (
        // Write Domain (Connected to Fast Clock and FIR)
        .wclk   (clk_fast),      // Ungated clock for safe CDC
        .wrst_n (rst_n),
        .wr_en  (fir_valid_out), // Write only when FIR output is valid
        .wdata  (fir_data_out),
        .wfull  (wfull),
        
        // Read Domain (Connected to Slow Clock and UART)
        .rclk   (clk_slow),
        .rrst_n (rst_n),
        .rd_en  (fifo_rinc),     // Read pulse generated by UART
        .rdata  (fifo_rdata),
        .rempty (fifo_empty)
    );

    // =================================================================
    // 5. UART Transmitter Top
    // =================================================================
    // Transmits the 16-bit FIFO data serially at the specified baud rate[cite: 80].
    uart_top #(
        .CLK_FREQ(UART_CLK_FREQ),
        .BAUD_RATE(UART_BAUD_RATE)
    ) uart_tx_inst (
        .clk_slow   (clk_slow),
        .rst_n      (rst_n),
        .fifo_empty (fifo_empty),
        .fifo_data  (fifo_rdata),
        .fifo_rinc  (fifo_rinc), // Feeds back to FIFO read enable
        .tx_serial  (tx_serial),
        .tx_busy    (tx_busy)
    );

endmodule