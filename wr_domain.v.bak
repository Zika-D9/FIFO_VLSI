module wr_domain #(
    parameter ADDR_WIDTH = 4
)(
    input  wire                    wr_clk,
    input  wire                    wr_rst_n,
    input  wire                    wr_en,
    input  wire [ADDR_WIDTH:0]     rd_ptr_gray_sync, // Synchronized from rd_clk
    output wire [ADDR_WIDTH-1:0]   wr_addr,
    output reg  [ADDR_WIDTH:0]     wr_ptr_gray,
    output reg                     full
);
    reg [ADDR_WIDTH:0] wr_ptr_bin;
    wire full_val;

    // Binary pointer logic
    always @(posedge wr_clk or negedge wr_rst_n) begin
        if (!wr_rst_n) begin
            wr_ptr_bin <= 0;
        end else if (wr_en && !full) begin
            wr_ptr_bin <= wr_ptr_bin + 1;
        end
    end

    // Direct memory indexing address
    assign wr_addr = wr_ptr_bin[ADDR_WIDTH-1:0];

    // Binary to Gray conversion
    always @(*) begin
        wr_ptr_gray = wr_ptr_bin ^ (wr_ptr_bin >> 1);
    end

    // Full Flag condition
    assign full_val = (wr_ptr_gray == {~rd_ptr_gray_sync[ADDR_WIDTH:ADDR_WIDTH-1], 
                                       rd_ptr_gray_sync[ADDR_WIDTH-2:0]});

    always @(posedge wr_clk or negedge wr_rst_n) begin
        if (!wr_rst_n) full <= 1'b0;
        else           full <= full_val;
    end
endmodule